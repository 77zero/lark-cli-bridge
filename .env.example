# ============================================================
# lark-cli-bridge 配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── 飞书应用凭证（必填）───────────────────────────────────
# 去 https://open.feishu.cn/app 创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CLI 工具配置 ──────────────────────────────────────────
# 可选值：opencode / claude
CLI_TYPE=opencode

# CLI 工作目录（CLI 在此目录下操作文件）
CLI_WORK_DIR=D:/project

# ── opencode serve 模式配置（推荐，支持会话持久化）───────
# serve 地址（留空则使用传统 opencode run，每次新建会话）
# OPENCODE_SERVE_URL=http://localhost:4096
# OPENCODE_SERVE_PASSWORD=
# OPENCODE_SERVE_PORT=4096
# OPENCODE_SERVE_AUTO_START=true

# ── 可选配置 ──────────────────────────────────────────────
# CLI 可执行文件路径（留空则自动从 PATH 查找）
# OPENCODE_PATH=opencode
# CLAUDE_PATH=claude

# 默认模型（仅 claude 模式有效）
# DEFAULT_MODEL=

# 流式推送间隔（字符数）
# STREAM_CHUNK_SIZE=20

# 上线通知接收人 open_id（启动时发送通知，留空不发送）
# OWNER_OPEN_ID=ou_xxxxxxxxxxxxxxxx


# ============================================================
# 多桥接模式（同时运行 opencode + claude 两个 bot）
# ============================================================
# 设置环境变量 BRIDGE_NAME 即可切换配置，前缀优先于默认值
#
# 方式一：命令行启动
#   $env:BRIDGE_NAME="claude"; python main.py
#   $env:BRIDGE_NAME="opencode"; python main.py
#
# 方式二：启动脚本一键启动两个进程
#   .\start_bridges.ps1
#
# claude 桥接覆盖配置：
# CLAUDE_FEISHU_APP_ID=cli_yyyyyyyyyyyyyyyy
# CLAUDE_FEISHU_APP_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
# CLAUDE_CLI_TYPE=claude
# CLAUDE_CLI_WORK_DIR=D:/project
# CLAUDE_OWNER_OPEN_ID=ou_yyyyyyyyyyyyyyyy
