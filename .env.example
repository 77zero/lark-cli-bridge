# ============================================================
# lark-cli-bridge 配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ════════════════════════════════════════════════════════════
# 一、基础配置
# ════════════════════════════════════════════════════════════
# 单桥接模式：必填
# 多桥接模式：如果第四节每个覆盖变量已填满，可不填；否则作为回退默认值

# 飞书应用凭证 —— 去 https://open.feishu.cn/app 创建企业自建应用
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用的 CLI 工具：opencode 或 claude
CLI_TYPE=opencode

# CLI 操作文件的工作目录
CLI_WORK_DIR=D:/project

# 上线通知接收人的飞书 open_id（留空不通知）
# OWNER_OPEN_ID=ou_xxxxxxxxxxxxxxxx

# 会话持久化目录（默认 ~/.cli_lark_bridge_{CLI_TYPE}，一般不用改）
# SESSIONS_DIR=~/.cli_lark_bridge_opencode


# ════════════════════════════════════════════════════════════
# 二、工具自身配置（不受 BRIDGE_NAME 影响，始终直接读取）
# ════════════════════════════════════════════════════════════

# ── opencode ────────────────────────────────────────────────
# 可执行文件路径（留空从 PATH 自动查找）
# OPENCODE_PATH=opencode

# serve 模式（推荐，支持会话持久化）
# OPENCODE_SERVE_URL=http://localhost:4096
# OPENCODE_SERVE_PASSWORD=
# OPENCODE_SERVE_PORT=4096
# OPENCODE_SERVE_AUTO_START=true

# ── claude ──────────────────────────────────────────────────
# 可执行文件路径（留空从 PATH 自动查找）
# CLAUDE_PATH=claude

# 指定模型（不填用 claude 默认值）
# DEFAULT_MODEL=


# ════════════════════════════════════════════════════════════
# 三、全局配置（不受 BRIDGE_NAME 影响，始终直接读取）
# ════════════════════════════════════════════════════════════

# 飞书 SDK 日志级别
# LOG_LEVEL=INFO

# 流式推送字符间隔
# STREAM_CHUNK_SIZE=20


# ════════════════════════════════════════════════════════════
# 四、多桥接覆盖配置（同时运行 opencode + claude 两个 bot）
# ════════════════════════════════════════════════════════════
#
# 命名规则：
#   BRIDGE_ + BRIDGE_NAME 大写 + _ + 原始变量名
#
#   例如 BRIDGE_NAME=opencode 时：
#     CLI_WORK_DIR  →  BRIDGE_OPENCODE_CLI_WORK_DIR
#     FEISHU_APP_ID →  BRIDGE_OPENCODE_FEISHU_APP_ID
#
# 启动方式：
#   BRIDGE_NAME=opencode python main.py
#   BRIDGE_NAME=claude   python main.py
#   或一键：.\start_bridges.ps1  /  ./start_bridges.sh
#
# 注意：每个桥接需要独立的飞书应用（不同 APP_ID/APP_SECRET），
#       否则两个 bot 会抢消息。
#
# 对照表：
# ┌──────────────┬──────────────────────────────────┬────────────────────────────────┐
# │ 原始变量      │ opencode 覆盖                    │ claude 覆盖                    │
# ├──────────────┼──────────────────────────────────┼────────────────────────────────┤
# │ FEISHU_APP_ID│ BRIDGE_OPENCODE_FEISHU_APP_ID    │ BRIDGE_CLAUDE_FEISHU_APP_ID    │
# │ FEISHU_APP…  │ BRIDGE_OPENCODE_FEISHU_APP_SECRET│ BRIDGE_CLAUDE_FEISHU_APP_SECRET│
# │ CLI_TYPE     │ BRIDGE_OPENCODE_CLI_TYPE         │ BRIDGE_CLAUDE_CLI_TYPE         │
# │ CLI_WORK_DIR │ BRIDGE_OPENCODE_CLI_WORK_DIR     │ BRIDGE_CLAUDE_CLI_WORK_DIR     │
# │ OWNER_OPEN_ID│ BRIDGE_OPENCODE_OWNER_OPEN_ID    │ BRIDGE_CLAUDE_OWNER_OPEN_ID    │
# │ SESSIONS_DIR │ BRIDGE_OPENCODE_SESSIONS_DIR     │ BRIDGE_CLAUDE_SESSIONS_DIR     │
# └──────────────┴──────────────────────────────────┴────────────────────────────────┘
#
# 注意：工具自身配置（OPENCODE_SERVE_URL, DEFAULT_MODEL 等）和全局配置
#       （LOG_LEVEL, STREAM_CHUNK_SIZE）不在此列，它们没有 BRIDGE_ 前缀，
#       始终直接读取，不受 BRIDGE_NAME 影响。

# ── opencode 桥接覆盖（BRIDGE_NAME=opencode 时优先读取）──
# BRIDGE_OPENCODE_FEISHU_APP_ID=cli_aaaaaaaaaaaaaaaa
# BRIDGE_OPENCODE_FEISHU_APP_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# BRIDGE_OPENCODE_CLI_TYPE=opencode
# BRIDGE_OPENCODE_CLI_WORK_DIR=D:/project
# BRIDGE_OPENCODE_OWNER_OPEN_ID=ou_aaaaaaaaaaaaaaaa

# ── claude 桥接覆盖（BRIDGE_NAME=claude 时优先读取）─────
# BRIDGE_CLAUDE_FEISHU_APP_ID=cli_bbbbbbbbbbbbbbbb
# BRIDGE_CLAUDE_FEISHU_APP_SECRET=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
# BRIDGE_CLAUDE_CLI_TYPE=claude
# BRIDGE_CLAUDE_CLI_WORK_DIR=D:/project
# BRIDGE_CLAUDE_OWNER_OPEN_ID=ou_bbbbbbbbbbbbbbbb
